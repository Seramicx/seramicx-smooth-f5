    {
      "config": "seramicx_smooth_f5.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "forgeconfigapiport": ">=8.0.0"
  }
}
